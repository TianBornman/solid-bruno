@page "/bookings/{Id:guid}"
@inject BookingState State
@inject CustomerState CustomerState
@inject VehicleState VehicleState
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@implements IDisposable

<PageTitle>Booking Details – Bruno Vehicle Hire</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4" Spacing="2">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                   OnClick="@(() => Nav.NavigateTo("/bookings"))" />
    <MudText Typo="Typo.h4">Booking Details</MudText>
</MudStack>

@if (State.IsLoading)
{
    <MudProgressLinear Color="Color.Tertiary" Indeterminate="true" />
}
else if (booking is null)
{
    <MudAlert Severity="Severity.Error">@(State.Error ?? "Booking not found.")</MudAlert>
}
else
{
    <MudGrid Spacing="4">
        <MudItem xs="12" md="4">
            <BookingCard Booking="booking"
                         CustomerName="@GetCustomerName(booking.CustomerId)"
                         VehicleLabel="@GetVehicleLabel(booking.VehicleId)" />
        </MudItem>

        <MudItem xs="12" md="8">
            <MudPaper Class="pa-6" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-4">Edit Booking</MudText>

                <BookingForm @ref="form"
                             Model="model"
                             Customers="CustomerState.Customers"
                             Vehicles="VehicleState.Vehicles"
                             IsEditMode="true" />

                @if (State.Error is not null)
                {
                    <MudAlert Severity="Severity.Error" Class="mt-4">@State.Error</MudAlert>
                }

                <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-6">
                    @if (CanDelete)
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Error"
                                   StartIcon="@Icons.Material.Filled.Delete"
                                   OnClick="ConfirmDeleteAsync">
                            Delete Booking
                        </MudButton>
                    }
                    else
                    {
                        <MudSpacer />
                    }

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Tertiary"
                               StartIcon="@Icons.Material.Filled.Save"
                               OnClick="SaveAsync"
                               Disabled="State.IsSaving">
                        @if (State.IsSaving)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <span>Saving...</span>
                        }
                        else
                        {
                            <span>Save Changes</span>
                        }
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private BookingForm form = null!;
    private BookingFormModel model = new();
    private BookingDto? booking;
    private CancellationTokenSource cts = new();

    private bool CanDelete => booking is not null
        && booking.Status == BookingStatus.Active
        && booking.StartDate.Date > DateTime.Today;

    protected override async Task OnInitializedAsync()
    {
        State.OnChange += StateHasChanged;
        CustomerState.OnChange += StateHasChanged;
        VehicleState.OnChange += StateHasChanged;

        await Task.WhenAll(
            LoadAsync(),
            CustomerState.LoadCustomers(cts.Token),
            VehicleState.LoadVehicles(cts.Token));
    }

    private async Task LoadAsync()
    {
        await State.LoadBooking(Id, cts.Token);
        booking = State.SelectedBooking;
        if (booking is not null)
            model = BookingFormModel.FromDto(booking);
    }

    private string GetCustomerName(Guid id)
    {
        var c = CustomerState.Customers.FirstOrDefault(x => x.Id == id);
        return c is null ? id.ToString() : $"{c.FirstName} {c.LastName}";
    }

    private string GetVehicleLabel(Guid id)
    {
        var v = VehicleState.Vehicles.FirstOrDefault(x => x.Id == id);
        return v is null ? id.ToString() : $"{v.RegistrationNumber} – {v.Make} {v.Model}";
    }

    private async Task SaveAsync()
    {
        if (!await form.ValidateAsync()) return;

        var success = await State.UpdateBooking(model.ToUpdateRequest(Id), cts.Token);
        if (success)
        {
            Snackbar.Add("Booking updated successfully.", Severity.Success);
            await LoadAsync();
        }
        else
        {
            Snackbar.Add(State.Error ?? "Failed to update booking.", Severity.Error);
        }
    }

    private async Task ConfirmDeleteAsync()
    {
        var parameters = new DialogParameters
        {
            ["Title"] = "Delete Booking",
            ["Message"] = $"Are you sure you want to delete this booking ({GetCustomerName(booking!.CustomerId)} / {GetVehicleLabel(booking.VehicleId)}, {booking.StartDate:dd MMM yyyy}–{booking.EndDate:dd MMM yyyy})? This cannot be undone.",
            ["ConfirmText"] = "Delete"
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Delete Booking", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            var success = await State.DeleteBooking(Id, cts.Token);
            if (success)
            {
                Snackbar.Add("Booking deleted.", Severity.Success);
                Nav.NavigateTo("/bookings");
            }
            else
            {
                Snackbar.Add(State.Error ?? "Failed to delete booking.", Severity.Error);
            }
        }
    }

    public void Dispose()
    {
        State.OnChange -= StateHasChanged;
        CustomerState.OnChange -= StateHasChanged;
        VehicleState.OnChange -= StateHasChanged;
        cts.Cancel();
        cts.Dispose();
    }
}
