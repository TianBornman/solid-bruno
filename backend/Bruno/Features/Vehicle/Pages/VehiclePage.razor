@page "/vehicles"
@inject IVehicleApi Api
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@implements IDisposable

<PageTitle>Vehicles – Bruno Vehicle Hire</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudText Typo="Typo.h4">Vehicles</MudText>
    <MudButton Variant="Variant.Filled"
               Color="Color.Secondary"
               StartIcon="@Icons.Material.Filled.AddCircle"
               OnClick="@(() => Nav.NavigateTo("/vehicles/create"))">
        Add Vehicle
    </MudButton>
</MudStack>

<MudPaper Class="pa-4 mb-4" Elevation="1">
    <MudTextField @bind-Value="searchTerm"
                  Placeholder="Search by registration, make or model..."
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  Clearable="true"
                  Class="flex-grow-1"
                  DebounceInterval="300" />
</MudPaper>

<VehicleList @ref="list"
             Search="@(string.IsNullOrWhiteSpace(searchTerm) ? null : searchTerm)"
             OnView="@(id => Nav.NavigateTo($"/vehicles/{id}"))"
             OnDelete="ConfirmDeleteAsync" />

@code {
    private VehicleList list = null!;
    private string searchTerm = string.Empty;
    private CancellationTokenSource cts = new();

    private async Task ConfirmDeleteAsync(VehicleDto vehicle)
    {
        var parameters = new DialogParameters
        {
            ["Title"] = "Delete Vehicle",
            ["Message"] = $"Are you sure you want to soft-delete {vehicle.Year} {vehicle.Make} {vehicle.Model} ({vehicle.RegistrationNumber})? It will no longer be available for booking.",
            ["ConfirmText"] = "Delete"
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Delete Vehicle", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            try
            {
                await Api.DeleteVehicle(vehicle.Id, cts.Token);
                Snackbar.Add("Vehicle deleted.", Severity.Success);
                await list.ReloadAsync();
            }
            catch (Exception ex)
            {
                Snackbar.Add(ex.Message, Severity.Error);
            }
        }
    }

    public void Dispose()
    {
        cts.Cancel();
        cts.Dispose();
    }
}
