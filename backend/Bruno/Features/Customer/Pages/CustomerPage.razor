@page "/customers"
@inject CustomerState State
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@implements IDisposable

<PageTitle>Customers – Bruno Vehicle Hire</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudText Typo="Typo.h4">Customers</MudText>
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.PersonAdd"
               OnClick="@(() => Nav.NavigateTo("/customers/create"))">
        New Customer
    </MudButton>
</MudStack>

<MudPaper Class="pa-4 mb-4" Elevation="1">
    <MudTextField @bind-Value="searchTerm"
                  Placeholder="Search by name, email or phone..."
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  Immediate="true"
                  Clearable="true"
                  FullWidth="true" />
</MudPaper>

@if (State.IsLoading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
}
else if (State.Error is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@State.Error</MudAlert>
}
else
{
    <CustomerList Customers="FilteredCustomers"
                  OnView="@(id => Nav.NavigateTo($"/customers/{id}"))"
                  OnDelete="ConfirmDeleteAsync" />
}

@code {
    private string searchTerm = string.Empty;
    private CancellationTokenSource cts = new();

    private IReadOnlyList<CustomerDto> FilteredCustomers =>
        string.IsNullOrWhiteSpace(searchTerm)
            ? State.Customers
            : State.Customers
                .Where(c =>
                    c.FirstName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                    c.LastName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                    c.Email.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                    c.PhoneNumber.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
                .ToList();

    protected override async Task OnInitializedAsync()
    {
        State.OnChange += StateHasChanged;
        await State.LoadCustomers(cts.Token);
    }

    private async Task ConfirmDeleteAsync(CustomerDto customer)
    {
        var parameters = new DialogParameters
        {
            ["Title"] = "Delete Customer",
            ["Message"] = $"Are you sure you want to delete {customer.FirstName} {customer.LastName}? This cannot be undone and will fail if they have active bookings.",
            ["ConfirmText"] = "Delete"
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Delete Customer", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            var success = await State.DeleteCustomer(customer.Id, cts.Token);
            Snackbar.Add(
                success ? "Customer deleted." : (State.Error ?? "Failed to delete customer."),
                success ? Severity.Success : Severity.Error);
        }
    }

    public void Dispose()
    {
        State.OnChange -= StateHasChanged;
        cts.Cancel();
        cts.Dispose();
    }
}
